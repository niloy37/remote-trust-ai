{
  "manifest_version": 3,
  "name": "RemoteTrust AI Job Reader",
  "version": "0.1.0",
  "description": "Read LinkedIn or Indeed job pages with user consent and analyze remote-job trust signals.",
  "action": {
    "default_title": "RemoteTrust AI",
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://www.linkedin.com/jobs/*",
    "https://linkedin.com/jobs/*",
    "https://*.linkedin.com/jobs/*",
    "https://www.indeed.com/*",
    "https://indeed.com/*",
    "https://*.indeed.com/*",
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://linkedin.com/jobs/*",
        "https://*.linkedin.com/jobs/*",
        "https://www.indeed.com/*",
        "https://indeed.com/*",
        "https://*.indeed.com/*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ]
}

